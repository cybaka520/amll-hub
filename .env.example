# ===== HTTP =====
PORT=8080

# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=ttml
DB_PASSWORD=ttml
DB_NAME=ttml_db
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ttml-db
MINIO_USE_SSL=false

# ===== RabbitMQ =====
RABBITMQ_URL=amqp://guest:guest@localhost:5672/amllhub
RABBITMQ_QUEUE=sync_queue
RABBITMQ_DLQ=sync_queue.dlq
RABBITMQ_NF_QUEUE=not_found_parse_queue
RABBITMQ_NF_DLQ=not_found_parse_queue.dlq

# ===== MeiliSearch =====
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=meili-master-key
MEILISEARCH_INDEX=songs

# ===== GitHub =====
GITHUB_TOKEN=
GITHUB_REPO=amll-dev/amll-ttml-db
GITHUB_BRANCH=main

# ===== Worker =====
WORKER_CONCURRENCY=20
WORKER_BATCH_SIZE=100
SYNC_LOCK_TTL=3600
INCREMENTAL_THRESHOLD=200

# ===== NCM API =====
NCM_API_BASE=https://ncmapi.bikonoo.com
NCM_MUSIC_U=

# ===== Casdoor =====
CASDOOR_ENDPOINT=http://localhost:8000
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ORGANIZATION=amll
CASDOOR_APPLICATION=amll-hub
CASDOOR_JWT_SECRET=
CASDOOR_JWT_TTL=24h
